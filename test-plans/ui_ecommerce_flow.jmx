        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Delete user creds" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.jmeter.services.FileServer
import java.nio.file.Paths

// JMeter base directory (where .jmx is located or the one specified via -d)
def baseDir = FileServer.getFileServer().getBaseDir()

// form a cross-platform path to the file users_creds.csv
def file = Paths.get(baseDir, &apos;users_creds.csv&apos;).toFile()

// if the file exists, delete it
if (file.exists()) {
    file.delete()
}

SampleResult.setIgnore()</stringProp>
          </JSR223Sampler>
