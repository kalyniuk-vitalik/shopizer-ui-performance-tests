              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set UPDATE_CART_PAYLOAD" enabled="true">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def update_item_payload = []

for(def i=1;i&lt;=vars.get(&quot;UPDATED_ITEM_ID_matchNr&quot;).toInteger();i++){
	if(i==1){
		quantity = vars.get(&quot;UPDATED_ITEM_QUANTITIES_&quot;+i).toInteger()+1
	} else quantity = vars.get(&quot;UPDATED_ITEM_QUANTITIES_&quot;+i).toInteger()
	
	update_item_payload.add(&apos;{&quot;id&quot;:&quot;&apos;+vars.get(&quot;UPDATED_ITEM_ID_&quot;+i)+&apos;&quot;,&quot;quantity&quot;:&quot;&apos;+vars.get(&quot;UPDATED_ITEM_QUANTITIES_&quot;+i)+&apos;&quot;,&quot;code&quot;:&quot;&apos;+vars.get(&quot;CART_CODE&quot;)+&apos;&quot;}&apos;)
}

vars.put(&quot;UPDATE_CART_ITEM&quot;,update_item_payload.join(&quot;,&quot;))</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>
              <hashTree/>
            </hashTree>
