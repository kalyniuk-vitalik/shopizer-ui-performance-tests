          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="SET USER_CREDENTIALS" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import org.apache.jmeter.services.FileServer
import java.nio.file.Paths

// Build email/password from generated credential and append to CSV
def PASSWORD = vars.get(&apos;EMAILPREFIX&apos;)          // ${EMAILPREFIX} from JMeter var in /register.html
def EMAIL = PASSWORD + &apos;@mailtest.net&apos;         

def baseDir = FileServer.getFileServer().getBaseDir()
def file = Paths.get(baseDir, &apos;users_creds.csv&apos;).toFile()

    // Write header once for new/empty file
    if (!file.exists() || file.length() == 0) {
        file &lt;&lt; &quot;EMAIL,PASSWORD&quot; + System.lineSeparator()
    }

    // Append one user row
    file &lt;&lt; &quot;${EMAIL},${PASSWORD}&quot; + System.lineSeparator()

</stringProp>
            </JSR223PostProcessor>
